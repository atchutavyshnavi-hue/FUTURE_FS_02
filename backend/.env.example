# Port the API server listens on
PORT=4000

# Secret used to sign admin JWT sessions - change this to a long random string in production
JWT_SECRET=replace-this-with-a-long-random-secret

# How long an admin login session stays valid
JWT_EXPIRES_IN=8h

# Default admin account created the first time the server starts (only if no admin exists yet)
DEFAULT_ADMIN_EMAIL=admin@miniCRM.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# Comma-separated list of origins allowed to call the API (your frontend URL(s))
CORS_ORIGIN=*